{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",

    "require": {
        "php": "^7.2",
        "laravel/framework": "6.20.*",
        "laravel/helpers": "^1.2",
        "laravel/tinker": "^1.0",
        "laravelcollective/html": "^6.2",
        "barryvdh/laravel-debugbar": "^3.2",
        "orchestra/imagine": "^4.0",
        "jeremykenedy/laravel-roles": "^3.0",
        "maatwebsite/excel": "3.1.30",
        "aws/aws-sdk-php-laravel": "3.0.23",
        "aws/aws-sdk-php": "3.133.0",
        "pda/pheanstalk": "^4.0",
        "doctrine/dbal": "^2.10",
        "tecnickcom/tcpdf": "^6.4",
        "docusign/esign-client": "^3.0",
        "fideloper/proxy": "^4.4",
        "devfactory/minify": "^1.0"
    },

    "require-dev": {
        "phpunit/phpunit": "^8.5",
        "mockery/mockery": "1.3.1",
        "facade/ignition": "^1.16"
    },

    "autoload": {
        "classmap": [
            "database/seeds"
        ],
        "psr-4": {
            "App\\": "app/",
            "Savitriya\\Icici_upi\\": "packages/savitriya/icici_upi/src"
        }
    },

    "autoload-dev": {
        "classmap": [
            "tests/TestCase.php"
        ]
    },

    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },

   "config": {
    "preferred-install": "dist",
    "platform": {
        "php": "7.2.34"
    },
    "audit": {
        "block-insecure": false
    },
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
},

    "minimum-stability": "stable",
    "prefer-stable": true
    
}
