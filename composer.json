{
	"name": "laravel/laravel",
	"description": "The Laravel Framework.",
	"keywords": ["framework", "laravel"],
	"license": "MIT",
	"type": "project",
	"require": {
		"laravel/framework": "5.0.*",
		"illuminate/html": "~5.0",
		"barryvdh/laravel-debugbar": "~2.0",
        "orchestra/imagine": "3.0.*",
		"piyushpatil/androidpushnotification": "dev-master",
		"maatwebsite/excel":"~2.0.0",
		"fabiang/xmpp": "*",
		  "pda/pheanstalk": "^3.1",
		"aws/aws-sdk-php-laravel": "~2.0",
        "doctrine/dbal": "^2.5",
		"bican/roles": "1.7.*",
	  	"devfactory/minify": "1.0.*",
        "tecnick.com/tcpdf": "~6.0.0",
		"docusign/esign-client": "*"

	},

	"require-dev": {
		"phpunit/phpunit": "~4.0",
		"phpspec/phpspec": "~2.1",
		"laracasts/generators": "~1.1"
	},
	"autoload": {
		"classmap": [
			"database"

		],
		"psr-4": {
			"App\\": "app/",
		  	"Savitriya\\Icici_upi\\": "packages/savitriya/icici_upi/src"
		}
	},
	"autoload-dev": {
		"classmap": [
			"tests/TestCase.php"
		]
	},
	"scripts": {
		"post-install-cmd": [
			"php artisan clear-compiled",
			"php artisan optimize"
		],
		"post-update-cmd": [
			"php artisan clear-compiled",
			"php artisan optimize"
		],
		"post-create-project-cmd": [
			"php -r \"copy('.env.example', '.env');\"",
			"php artisan key:generate"
		]
	},
	"config": {
		"preferred-install": "dist"
	}
    
}
